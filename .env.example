# ── Capital ─────────────────────────────────────────────────────
INITIAL_CAPITAL=10000          # Capital ficticio en la moneda de DISPLAY_CURRENCY (EUR por defecto)

# ── Moneda de visualización ──────────────────────────────────────
DISPLAY_CURRENCY=EUR           # EUR o USD

# ── Modo trading ─────────────────────────────────────────────────
TRADING_MODE=paper             # solo "paper" por ahora

# ── Noticias (opcional) ──────────────────────────────────────────
NEWS_API_KEY=                  # Clave gratuita en newsapi.org (opcional)
