# ════════════════════════════════════════════════════════════════
# TELEGRAM — alertas en tiempo real (MUY RECOMENDADO, 5 min de setup)
# ════════════════════════════════════════════════════════════════
# 1. Abre Telegram → @BotFather → /newbot → guarda el TOKEN
# 2. Manda cualquier mensaje a tu nuevo bot
# 3. Abre: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Busca  "chat":{"id": XXXXXXX}  → ese número es tu CHAT_ID
TELEGRAM_BOT_TOKEN=            # ej: 123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=              # ej: 987654321

# ════════════════════════════════════════════════════════════════
# OPCIONES — flujo inusual (no requiere API key, scraping automático)
# ════════════════════════════════════════════════════════════════
OPTIONS_FLOW_ENABLED=true

# ── Capital ─────────────────────────────────────────────────────
INITIAL_CAPITAL=10000          # Capital ficticio en la moneda de DISPLAY_CURRENCY (EUR por defecto)

# ── Moneda de visualización ──────────────────────────────────────
DISPLAY_CURRENCY=EUR           # EUR o USD

# ── Modo trading ─────────────────────────────────────────────────
TRADING_MODE=paper             # solo "paper" por ahora

# ── Noticias ─────────────────────────────────────────────────────
NEWS_API_KEY=                  # newsapi.org — gratis hasta 100 req/día

# ── Finnhub (recomendado — gratis, 60 req/min) ───────────────────
# Registro en: https://finnhub.io  → "Get free API key"
FINNHUB_API_KEY=               # Noticias en tiempo real + sentimiento por empresa

# ── Alpha Vantage (recomendado — gratis, 25 req/día) ─────────────
# Registro en: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=             # Sentimiento de noticias con relevancia por ticker

# ── Reddit PRAW (opcional — gratis) ──────────────────────────────
# 1. Ve a https://www.reddit.com/prefs/apps
# 2. Crea app de tipo "script", redirect URI = http://localhost:8080
# 3. Copia el client_id (bajo el nombre) y el secret
REDDIT_CLIENT_ID=              # r/wallstreetbets + r/investing + r/stocks
REDDIT_CLIENT_SECRET=
